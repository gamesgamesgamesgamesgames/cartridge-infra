#!/bin/bash
set -euo pipefail

BACKUP_DIR="{{ pg_backup_dir }}"
RETENTION_DAYS="{{ pg_backup_retention_days }}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/happyview_${TIMESTAMP}.sql.gz"

# Dump via the running postgres container
docker exec postgres pg_dump -U {{ postgres_user }} {{ postgres_db }} | gzip > "${BACKUP_FILE}"

# Remove backups older than retention period
find "${BACKUP_DIR}" -name "happyview_*.sql.gz" -mtime +${RETENTION_DAYS} -delete

echo "Backup complete: ${BACKUP_FILE}"
