volumes:
  metadata_data: {}
  middle_var: {}
  historical_var: {}
  broker_var: {}
  coordinator_var: {}
  router_var: {}
  druid_shared: {}
  minio_data: {}
  caddy_data: {}
  caddy_config: {}

services:
  caddy:
    image: caddy:2
    container_name: caddy
    network_mode: host
    volumes:
      - {{ data_dir }}/Caddyfile:/etc/caddy/Caddyfile
      - caddy_data:/data
      - caddy_config:/config
    restart: unless-stopped

  osprey-kafka:
    image: {{ kafka_image }}
    hostname: osprey-kafka
    container_name: osprey-kafka
    ports:
      - "127.0.0.1:{{ kafka_port }}:9092"
    environment:
      KAFKA_NODE_ID: 1
      KAFKA_PROCESS_ROLES: "broker,controller"
      KAFKA_CONTROLLER_QUORUM_VOTERS: "1@osprey-kafka:29093"
      KAFKA_CONTROLLER_LISTENER_NAMES: "CONTROLLER"
      KAFKA_INTER_BROKER_LISTENER_NAME: "INTERNAL"
      KAFKA_LISTENERS: "INTERNAL://osprey-kafka:29092,EXTERNAL://0.0.0.0:9092,CONTROLLER://osprey-kafka:29093"
      KAFKA_ADVERTISED_LISTENERS: "INTERNAL://osprey-kafka:29092,EXTERNAL://localhost:9092"
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: "INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT"
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: 0
      CLUSTER_ID: "P45WxmmWSe2CrdGoeJMcKg"
    healthcheck:
      test: ["CMD", "bash", "-c", "kafka-topics --bootstrap-server osprey-kafka:29092 --list"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  osprey-kafka-topic-creator:
    image: {{ kafka_image }}
    depends_on:
      osprey-kafka:
        condition: service_healthy
    command: >
      bash -c "
        kafka-topics --bootstrap-server osprey-kafka:29092 --create --if-not-exists --topic osprey.actions_input --partitions 3 --replication-factor 1 &&
        kafka-topics --bootstrap-server osprey-kafka:29092 --create --if-not-exists --topic osprey.execution_results --partitions 3 --replication-factor 1 &&
        kafka-topics --bootstrap-server osprey-kafka:29092 --list
      "
    restart: "no"

  postgres:
    image: {{ postgres_image }}
    hostname: postgres
    container_name: postgres
    ports:
      - "127.0.0.1:{{ postgres_port }}:5432"
    volumes:
      - metadata_data:/var/lib/postgresql
    environment:
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_USER: {{ postgres_user }}
      POSTGRES_DB: {{ postgres_db }}
    healthcheck:
      test: pg_isready -U {{ postgres_user }} -d {{ postgres_db }}
      start_period: 30s
      interval: 10s
      timeout: 10s
      retries: 5
    restart: unless-stopped

  minio:
    image: {{ minio_image }}
    hostname: minio
    container_name: minio
    ports:
      - "127.0.0.1:{{ minio_port }}:9000"
      - "127.0.0.1:{{ minio_console_port }}:9001"
    environment:
      MINIO_ROOT_USER: {{ minio_access_key }}
      MINIO_ROOT_PASSWORD: {{ minio_secret_key }}
    volumes:
      - minio_data:/data
    command: server --console-address ":9001" /data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: unless-stopped

  minio-bucket-init:
    image: minio/mc:latest
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: ["/bin/sh", "/init-minio-bucket.sh"]
    volumes:
      - {{ data_dir }}/init-minio-bucket.sh:/init-minio-bucket.sh
    restart: "no"

  snowflake-id-worker:
    image: {{ snowflake_image }}
    hostname: snowflake-id-worker
    container_name: snowflake-id-worker
    ports:
      - "127.0.0.1:8088:8088"
    environment:
      WORKER_ID: 0
      DATA_CENTER_ID: 0
      EPOCH: 1420070400000
      PORT: 8088
    restart: unless-stopped

  bigtable:
    hostname: bigtable
    container_name: bigtable
    image: gcr.io/google.com/cloudsdktool/cloud-sdk:latest
    ports:
      - "127.0.0.1:8361:8361"
    command: >
      bash -c "gcloud beta emulators bigtable start --host-port=0.0.0.0:8361 --project=osprey-dev"
    healthcheck:
      test: ["CMD", "bash", "-c", "pgrep -f cbtemulator > /dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  bigtable-initializer:
    image: gcr.io/google.com/cloudsdktool/cloud-sdk:latest
    depends_on:
      bigtable:
        condition: service_healthy
    volumes:
      - {{ data_dir }}/init-bigtable.sh:/init-bigtable.sh
    command: ["/bin/bash", "/init-bigtable.sh"]
    restart: "no"

  osprey-worker:
    image: {{ osprey_worker_image }}
    hostname: osprey-worker
    container_name: osprey-worker
    depends_on:
      osprey-kafka:
        condition: service_healthy
      osprey-kafka-topic-creator:
        condition: service_completed_successfully
      minio:
        condition: service_healthy
      minio-bucket-init:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
    ports:
      - "127.0.0.1:{{ osprey_worker_port }}:5000"
    command: ["osprey-worker"]
    environment:
      PYTHONPATH: /osprey
      PORT: "5000"
      POSTGRES_HOSTS: '{"osprey_db":"postgresql://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_db }}"}'
      OSPREY_INPUT_STREAM_SOURCE: kafka
      OSPREY_STDOUT_OUTPUT_SINK: "True"
      OSPREY_KAFKA_BOOTSTRAP_SERVERS: '["osprey-kafka:29092"]'
      OSPREY_KAFKA_INPUT_STREAM_TOPIC: osprey.actions_input
      OSPREY_KAFKA_INPUT_STREAM_CLIENT_ID: localhost
      OSPREY_KAFKA_OUTPUT_SINK: "True"
      OSPREY_KAFKA_OUTPUT_TOPIC: osprey.execution_results
      OSPREY_KAFKA_OUTPUT_CLIENT_ID: localhost
      DD_TRACE_ENABLED: "False"
      DD_DOGSTATSD_DISABLE: "True"
      OSPREY_RULES_SINK_NUM_WORKERS: "1"
      BIGTABLE_EMULATOR_HOST: bigtable:8361
      OSPREY_EXECUTION_RESULT_STORAGE_BACKEND: minio
      OSPREY_MINIO_ENDPOINT: minio:9000
      OSPREY_MINIO_ACCESS_KEY: {{ minio_access_key }}
      OSPREY_MINIO_SECRET_KEY: {{ minio_secret_key }}
      OSPREY_MINIO_SECURE: "false"
      OSPREY_MINIO_EXECUTION_RESULTS_BUCKET: {{ minio_bucket }}
      SNOWFLAKE_API_ENDPOINT: http://snowflake-id-worker:8088
      OSPREY_RULES_PATH: /osprey/rules
    volumes:
      - {{ data_dir }}/rules:/osprey/rules
    restart: unless-stopped

  osprey-ui-api:
    image: {{ osprey_worker_image }}
    hostname: osprey-ui-api
    container_name: osprey-ui-api
    depends_on:
      - osprey-worker
      - druid-broker
      - postgres
      - snowflake-id-worker
    ports:
      - "127.0.0.1:{{ osprey_api_port }}:5004"
    command: ["osprey-ui-api"]
    environment:
      PYTHONPATH: /osprey
      PORT: "5004"
      DRUID_URL: http://druid-broker:8082
      POSTGRES_HOSTS: '{"osprey_db":"postgresql://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_db }}"}'
      DD_TRACE_ENABLED: "False"
      DD_DOGSTATSD_DISABLE: "True"
      OSPREY_RULES_PATH: /osprey/rules
      OSPREY_DISABLE_VALIDATION_EXPORTER: "true"
      BIGTABLE_EMULATOR_HOST: bigtable:8361
      SNOWFLAKE_API_ENDPOINT: http://snowflake-id-worker:8088
      SNOWFLAKE_EPOCH: "1420070400000"
    volumes:
      - {{ data_dir }}/rules:/osprey/rules
    restart: unless-stopped

  osprey-ui:
    image: {{ osprey_ui_image }}
    hostname: osprey-ui
    container_name: osprey-ui
    depends_on:
      - osprey-ui-api
    ports:
      - "127.0.0.1:{{ osprey_ui_port }}:5002"
    environment:
      REACT_APP_API_BASE_URL: https://{{ osprey_ui_hostname }}
    entrypoint: ["/bin/sh", "/app/entrypoint.sh"]
    volumes:
      - {{ data_dir }}/osprey-ui-entrypoint.sh:/app/entrypoint.sh
    restart: unless-stopped

  # --- Druid cluster ---
  druid-zookeeper:
    hostname: druid-zookeeper
    container_name: druid-zookeeper
    image: zookeeper:3.5.10
    ports:
      - "127.0.0.1:2181:2181"
    environment:
      ZOO_MY_ID: 1
    restart: unless-stopped

  druid-coordinator:
    image: {{ druid_image }}
    hostname: druid-coordinator
    container_name: druid-coordinator
    volumes:
      - druid_shared:/opt/shared
      - coordinator_var:/opt/druid/var
    depends_on:
      - druid-zookeeper
      - postgres
    ports:
      - "127.0.0.1:8081:8081"
    command: ["coordinator"]
    env_file:
      - {{ data_dir }}/druid.env
    restart: unless-stopped

  druid-broker:
    image: {{ druid_image }}
    hostname: druid-broker
    container_name: druid-broker
    volumes:
      - broker_var:/opt/druid/var
    depends_on:
      - druid-zookeeper
      - postgres
      - druid-coordinator
    ports:
      - "127.0.0.1:8082:8082"
    command: ["broker"]
    env_file:
      - {{ data_dir }}/druid.env
    restart: unless-stopped

  druid-historical:
    image: {{ druid_image }}
    hostname: druid-historical
    container_name: druid-historical
    volumes:
      - druid_shared:/opt/shared
      - historical_var:/opt/druid/var
    depends_on:
      - druid-zookeeper
      - postgres
      - druid-coordinator
    ports:
      - "127.0.0.1:8083:8083"
    command: ["historical"]
    env_file:
      - {{ data_dir }}/druid.env
    restart: unless-stopped

  druid-middlemanager:
    image: {{ druid_image }}
    hostname: druid-middlemanager
    container_name: druid-middlemanager
    volumes:
      - druid_shared:/opt/shared
      - middle_var:/opt/druid/var
    depends_on:
      - druid-zookeeper
      - postgres
      - druid-coordinator
    ports:
      - "127.0.0.1:8091:8091"
      - "127.0.0.1:8100-8105:8100-8105"
    command: ["middleManager"]
    env_file:
      - {{ data_dir }}/druid.env
    restart: unless-stopped

  druid-router:
    image: {{ druid_image }}
    hostname: druid-router
    container_name: druid-router
    volumes:
      - router_var:/opt/druid/var
    depends_on:
      - druid-zookeeper
      - postgres
      - druid-coordinator
    ports:
      - "127.0.0.1:{{ druid_router_port }}:8888"
    command: ["router"]
    env_file:
      - {{ data_dir }}/druid.env
    restart: unless-stopped
